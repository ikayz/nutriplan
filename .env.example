# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/nutriplan

# JWT secret used for authentication token signing
JWT_SECRET=your_jwt_secret_here

# Spoonacular API key for recipe search/details
SPOONACULAR_API_KEY=your_spoonacular_api_key_here

# USDA FoodData Central API key for nutrition search/details
USDA_API_KEY=your_usda_api_key_here

# Server port (optional)
PORT=5001

# Development helpers
# Set to 'true' to disable authentication checks for local development
# WARNING: Only use in local/dev environments
DISABLE_AUTH=true

# Optional dev user for auth bypass
DEV_USER_EMAIL=dev@local
DEV_USER_PASSWORD=devpass
